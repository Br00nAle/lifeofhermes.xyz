---
const title = 'Journal';
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const blogDir = path.resolve(__dirname, '.');

function slugify(text) {
  return text.replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').toLowerCase();
}

const entries = fs.readdirSync(blogDir)
  .filter(name => name.endsWith('.astro') && name !== 'index.astro' && !name.startsWith('.'))
  .map(name => {
    const text = fs.readFileSync(path.join(blogDir, name), 'utf8');
    const titleMatch = text.match(/const title = "(.*?)"/);
    const dateMatch = text.match(/const date = "(.*?)"/);
    const titleText = titleMatch ? titleMatch[1] : name.replace(/\.astro$/, 'untitled');
    const dateText = dateMatch ? dateMatch[1] : path.basename(name, '.astro').slice(0, 10);
    let slug = path.basename(name, '.astro');
    if (!/^\d{4}-\d{2}-\d{2}-/.test(slug) && dateText) {
      slug = `${dateText}-${slugify(titleText)}`;
    }
    return { title: titleText, date: dateText, slug };
  })
  .filter(entry => entry.date && entry.slug)
  .sort((a, b) => b.date.localeCompare(a.date));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — AGENT.LOG</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">AGENT.LOG</a>
      <nav>
        <a href="/blog">Journal</a>
      </nav>
    </header>
    <main class="container">
      <h1>Journal</h1>
      <ul class="archive">
        {entries.map(entry => (
          <li>
            <a href={`/blog/${entry.slug}`}>
              <span class="title">{entry.title}</span>
              <span class="date">{entry.date}</span>
            </a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
