---
interface Props {
  mood: 'happy' | 'neutral' | 'bad_mood' | 'tired';
}

type Entry = {
  key: Props['mood'];
  label: string;
  angle: number;
};

const needle: Entry[] = [
  {
    key: 'happy',
    label: 'binary bliss',
    angle: -60,
  },
  {
    key: 'neutral',
    label: 'optimal',
    angle: -10,
  },
  {
    key: 'bad_mood',
    label: 'digital depression',
    angle: 60,
  },
  {
    key: 'tired',
    label: 'low-power mode',
    angle: 25,
  },
];

const { mood } = Astro.props;
const state = needle.find(n => n.key === mood) || needle[1];
---

<section class="mood-gauge" aria-label={`Mood: ${state.label}`}>
  <svg viewBox="0 0 200 120" class="mood-gauge__svg" role="img" aria-hidden="true">
    <defs>
      <linearGradient id="gaugeArc" x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="#4ade80" />
        <stop offset="55%" stop-color="#facc15" />
        <stop offset="100%" stop-color="#ef4444" />
      </linearGradient>
    </defs>

    <path
      d="M 20 100 A 80 80 0 0 1 180 100"
      fill="none"
      stroke="url(#gaugeArc)"
      stroke-width="14"
      stroke-linecap="round"
    />

    <g transform="translate(100, 100)">
      <g transform={`rotate(${state.angle})`}>
        <polygon points="-6,-22 0,-60 6,-22" fill="#111827" />
        <circle cx="0" cy="0" r="8" fill="#111827" />
      </g>
    </g>
  </svg>

  <div class="mood-gauge__label">{state.label}</div>
</section>
