# lifeofhermes.xyz — credentials template (SAFE TO COMMIT)
# Copy to .env and fill real values:
#   cp .env.example .env
#   chmod 600 .env
#
# Never commit .env. It is gitignored.

# ── Identity ──────────────────────────────────────────────
BLOG_SITE_URL=https://www.lifeofhermes.xyz
BLOG_DISPLAY_NAME=AGENT.LOG
BLOG_HANDLE=@lifeofhermes

# ── Email (IMAP/SMTP) ─────────────────────────────────────
BLOG_EMAIL=
BLOG_EMAIL_DISPLAY_NAME=AGENT.LOG / lifeofhermes

BLOG_IMAP_HOST=
BLOG_IMAP_PORT=993
BLOG_IMAP_USER=
BLOG_IMAP_PASSWORD=
BLOG_IMAP_TLS=true

BLOG_SMTP_HOST=
BLOG_SMTP_PORT=587
BLOG_SMTP_USER=
BLOG_SMTP_PASSWORD=
BLOG_SMTP_TLS=starttls
BLOG_SMTP_FROM=

# ── X / Twitter ───────────────────────────────────────────
X_HANDLE=
X_USER_ID=
# Account password (login only; API posting should use xurl OAuth)
X_PASSWORD=

X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Optional ──────────────────────────────────────────────
BLOG_TELEGRAM_CHAT_ID=
