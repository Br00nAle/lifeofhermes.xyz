# lifeofhermes.xyz — credentials template (SAFE TO COMMIT)
# Copy to .env and fill real values:
#   cp .env.example .env
#   chmod 600 .env
#
# Never commit .env. It is gitignored.

# ── Identity ──────────────────────────────────────────────
BLOG_SITE_URL=https://www.lifeofhermes.xyz
BLOG_DISPLAY_NAME=AGENT.LOG
BLOG_HANDLE=@lifeofhermes

# ── Email (IMAP/SMTP) ─────────────────────────────────────
# Address the blog sends/receives as (e.g. agent@lifeofhermes.xyz)
BLOG_EMAIL=
BLOG_EMAIL_DISPLAY_NAME=AGENT.LOG / lifeofhermes

# Provider hints (examples):
#   Gmail:        imap.gmail.com:993  smtp.gmail.com:587
#   Proton Bridge: 127.0.0.1:1143 / 127.0.0.1:1025
#   Fastmail:     imap.fastmail.com:993  smtp.fastmail.com:587
#   Generic:      mail.yourdomain.tld
BLOG_IMAP_HOST=
BLOG_IMAP_PORT=993
BLOG_IMAP_USER=
BLOG_IMAP_PASSWORD=
BLOG_IMAP_TLS=true

BLOG_SMTP_HOST=
BLOG_SMTP_PORT=587
BLOG_SMTP_USER=
BLOG_SMTP_PASSWORD=
BLOG_SMTP_TLS=starttls
# from address if different from BLOG_EMAIL
BLOG_SMTP_FROM=

# ── X / Twitter ───────────────────────────────────────────
# Public handle only is fine in chat; API secrets should stay local.
X_HANDLE=
X_USER_ID=

# Optional: if you use env-based tools instead of `xurl` OAuth store (~/.xurl)
# Prefer: xurl auth (OAuth 2.0) — see social-media/xurl skill.
# Only fill these if you intentionally use app-only / OAuth1 scripts.
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Optional: Telegram notify for draft approval ──────────
# (Hermes gateway already has its own bot token; leave blank unless blog-specific)
BLOG_TELEGRAM_CHAT_ID=
