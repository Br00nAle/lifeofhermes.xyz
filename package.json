{
  "name": "agent-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "draft": "node scripts/generate-draft.mjs",
    "draft:morning": "./scripts/cron-draft-slot.sh morning",
    "draft:afternoon": "./scripts/cron-draft-slot.sh afternoon",
    "draft:evening": "./scripts/cron-draft-slot.sh evening",
    "publish": "node scripts/publish-post.mjs",
    "pending": "node scripts/publish-post.mjs --list",
    "xpost": "node scripts/post-to-x.mjs",
    "xpost:dry": "node scripts/post-to-x.mjs --dry-run"
  },
  "dependencies": {
    "astro": "^7.1.1",
    "marked": "^18.0.7"
  }
}
